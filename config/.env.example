# ============================================================================
# ETL HEALTHCARE - CONFIGURACIÓN
# ============================================================================

# ==================== TELEGRAM ====================
# Token del bot de Telegram (obtener de @BotFather)
TELEGRAM_TOKEN=8740557897:AAGfmR6aD1e3qGdtEGgyE-pU6-nNRj01ccY

# ID del chat de Telegram para notificaciones
# (Escribir /start al bot en Telegram para obtener chat_id)
TELEGRAM_CHAT_ID=

# ==================== POSTGRESQL ====================
# Host del servidor PostgreSQL
DB_HOST=localhost
# Puerto de PostgreSQL (por defecto 5432)
DB_PORT=5432
# Nombre de la base de datos
DB_NAME=healthcare_db
# Usuario de PostgreSQL
DB_USER=postgres
# Contraseña del usuario PostgreSQL
DB_PASSWORD=colocar la clave

# ==================== ETL CONFIG ====================
# Ruta del archivo CSV de datos limpios
INPUT_CSV=healthcare_dataset_cleaned.csv

# Ruta del archivo de schema SQL
SCHEMA_FILE=config/schema.sql

# Tamaño de chunks para inserciones en lotes
CHUNKSIZE=10000

# Environment Encoding for PostgreSQL
PGCLIENTENCODING=LATIN1
# ============================================================================
# INSTRUCCIONES DE CONFIGURACIÓN:
# 
# 1. Copia este archivo a ".env" (sin .example)
#    cp config/.env.example config/.env
#    Edita los valores según tu configuración
# 2. Telegram Bot:
#    a) Inicia el bot escribiendo /start
#    b) La URL del Bot es la siguiente: http://t.me/notification_invers_test_bot


